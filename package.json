{
  "name": "zkgl",
  "version": "0.1.0",
  "private": true,
  "description": "众肯科技项目全过程管理系统",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @zkgl/web",
    "build": "npm run build -ws --if-present",
    "build:function": "npm run build -w @zkgl/api && node scripts/prepare-cloudbase-function.mjs",
    "test": "npm run test -ws --if-present",
    "typecheck": "npm run typecheck -ws --if-present"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
