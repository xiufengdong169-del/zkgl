{
  "$schema": "https://static.cloudbase.net/cli/cloudbaserc.schema.json",
  "version": "2.0",
  "envId": "cloudbase-d7gc2b32cd4196059",
  "functionRoot": "./functions",
  "functions": [
    {
      "name": "zkgl-api",
      "dir": "./zkgl-api",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "timeout": 20,
      "memorySize": 512,
      "installDependency": true
    },
    {
      "name": "zkgl-reminder",
      "dir": "./zkgl-reminder",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "timeout": 60,
      "memorySize": 256,
      "installDependency": true,
      "triggers": [
        {
          "name": "zkglDailyReminder",
          "type": "timer",
          "config": "0 0 8 * * * *"
        }
      ]
    }
  ]
}
